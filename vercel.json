{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "backend/server.js"
    },
    {
      "source": "/uploads/:path*",
      "destination": "backend/server.js"
    },
    {
      "source": "/((?!api|uploads).*):path*",
      "destination": "frontend/$1:path*"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "1"
  }
}
